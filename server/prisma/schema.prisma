// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───

enum Role {
  Agriculteur
  Saisonnier
  Public
}

enum StatutAnnonce {
  Brouillon
  Cloturee
  Active
}

enum StatutCandidature {
  En_Attente
  En_Cours_d_Evaluation
  Acceptée
  Refusée
}

// ─── User ───

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role
  prenom    String
  nom       String
  telephone Int

 // Relations 
  exploitation Exploitation?
  saisonnier   Saisonnier?
  annonces Annonce[] @relation("AnnoncesAgriculteur")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Exploitation ───

model Exploitation {
  id     String @id @default(uuid())

  // Relation 1-à-1 avec User
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  nomExploitation String
  siret           Int

  // Une exploitation publie plusieurs annonces
  annonces Annonce[]
}

// ─── Saisonnier ───

model Saisonnier {
  id String @id @default(uuid())

  // Relation 1-à-1 avec User
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Un saisonnier a plusieurs documents et candidatures
  documents    Document[]
  candidatures Candidature[]
}

// ─── Document ───

model Document {
  id String @id @default(uuid())

  // Relation plusieurs-à-1 avec Saisonnier
  saisonnierId String
  saisonnier   Saisonnier @relation(fields: [saisonnierId], references: [id])

  label String
  cvUrl String?
}

// ─── Annonce ───

model Annonce {

id String @id @default(uuid())

  // Relation Exploitation
  exploitationId String
  exploitation   Exploitation @relation(fields: [exploitationId], references: [id])

  agriculteurId String
  agriculteur   User @relation("AnnoncesAgriculteur", fields: [agriculteurId], references: [id])

  titre          String
  statut         StatutAnnonce @default(Active)
  nombreDePostes Int
  hebergement    String
  remuneration   Float
  competences    String
  domaine        String
  type           String
  dates          DateTime
  date_debut     DateTime
  date_fin       DateTime

  // Une annonce reçoit plusieurs candidatures
  candidatures Candidature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Candidature ───

model Candidature {
  id String @id @default(uuid())

  // Relation vers Annonce
  annonceId String
  annonce   Annonce @relation(fields: [annonceId], references: [id])

 // Relation vers Saisonnier
  saisonnierId String
  saisonnier   Saisonnier @relation(fields: [saisonnierId], references: [id])

  message String
  statut  StatutCandidature @default(En_Attente)

  // Fil de messages liés à cette candidature
  messages Message[]

  createdAt DateTime @default(now())

  @@unique([annonceId, saisonnierId])
}

// ─── Message ───

model Message {
  id String @id @default(uuid())

  // Relation vers Candidature
  candidatureId String
  candidature   Candidature @relation(fields: [candidatureId], references: [id])

  msg       String
  createdAt DateTime @default(now())
}

