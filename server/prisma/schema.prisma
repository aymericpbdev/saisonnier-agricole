// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───
enum Role {
  Agriculteur
  Saisonnier
  Public
}

enum StatutAnnonce {
  Brouillon
  Cloturee
  Active
}

enum StatutCandidature {
  EnAttente
  EnCoursEvaluation
  Acceptee
  Refusee
}

enum Competences {
  Recolte
  Plantation
  Viticulture
  Elevage
  ConduiteEngins
  Traite
  Arboriculture
  Maraichage
}

enum TypeCulture {
  Cereales
  Fruits
  Legumes
  Vigne
  Oliviers
  Horticulture
  Elevage
  Maraichage
  GrandesCultures
}

enum TypeRemuneration {
  ParHeure
  ParSemaine
  ParMois
}

enum TypeHoraire {
  TempsPlein
  TempsPartiel
  Journee
  Nuit
  WeekEnd
  Flexible
}

// ─── User ───
model User {
  id        String  @id @default(uuid())
  email     String  @unique
  password  String
  role      Role
  prenom    String
  nom       String
  telephone String?

  // Relations 
  exploitation Exploitation?
  saisonnier   Saisonnier?
  annonces     Annonce[]     @relation("AnnoncesAgriculteur")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Exploitation ───
model Exploitation {
  id String @id @default(uuid())

  // Relation 1-à-1 avec User
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  nomExploitation String
  siret           String
  ville           String
  codePostal      String
  departement     String

  // Une exploitation publie plusieurs annonces
  annonces Annonce[]
}

// ─── Saisonnier ───
model Saisonnier {
  id String @id @default(uuid())

  // Relation 1-à-1 avec User
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Informations profil
  ville          String
  competences    Competences[]
  disponibiliteDebut DateTime?
  disponibiliteFin   DateTime?
  ville String
  compétences String[]
  ville       String
  codePostal  String
  departement String

  // Un saisonnier a plusieurs documents et candidatures
  documents    Document[]
  candidatures Candidature[]
}

// ─── Document ───
model Document {
  id String @id @default(uuid())

  // Relation plusieurs-à-1 avec Saisonnier
  saisonnierId String
  saisonnier   Saisonnier @relation(fields: [saisonnierId], references: [id])

  label String
  cvUrl String?
}

// ─── Annonce ───
model Annonce {
  id String @id @default(uuid())

  // Relation Exploitation
  exploitationId String
  exploitation   Exploitation @relation(fields: [exploitationId], references: [id])

  agriculteurId String
  agriculteur   User   @relation("AnnoncesAgriculteur", fields: [agriculteurId], references: [id])

  titre            String
  statut           StatutAnnonce    @default(Brouillon)
  nombreDePostes   Int
  hebergement      Boolean          @default(false)
  remuneration     Decimal
  typeRemuneration TypeRemuneration @default(ParHeure)
  competences      Competences[]
  domaine          String
  typeHoraire      TypeHoraire[]
  dateFin          DateTime
  dateDebut        DateTime
  typeCulture      TypeCulture[]
  localisation     String
  descriptionAnnonce  String

  // Une annonce reçoit plusieurs candidatures
  candidatures Candidature[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Candidature ───
model Candidature {
  id String @id @default(uuid())

  // Relation vers Annonce
  annonceId String
  annonce   Annonce @relation(fields: [annonceId], references: [id])

  // Relation vers Saisonnier
  saisonnierId String
  saisonnier   Saisonnier @relation(fields: [saisonnierId], references: [id])

  statut StatutCandidature @default(EnAttente)

// Fil de messages liés à cette candidature
  messageMotivation MessageMotivation[]

    crééÀ DateTime @default(now())

  @@unique([annonceId, saisonnierId])
}
